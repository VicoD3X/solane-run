{
  "name": "solane-run",
  "private": true,
  "version": "0.1.0",
  "description": "Solane Run freight calculator monorepo.",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "build:web": "npm --workspace apps/web run build",
    "lint:web": "npm --workspace apps/web run lint",
    "preview:web": "npm --workspace apps/web run preview",
    "test:api": "py -m pytest apps/api/tests",
    "dev:api": "py -m uvicorn app.main:app --reload --app-dir apps/api"
  }
}
